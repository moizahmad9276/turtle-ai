generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Translation {
  id         Int      @id @default(autoincrement())
  key        String
  language   String   @db.Char(2)
  value      String   @db.Text
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([key, language])
  @@index([language])
  @@index([key])
  @@map("translations")
}
